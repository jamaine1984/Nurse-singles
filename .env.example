# Firebase Configuration
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_APP_ID=your_firebase_app_id
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_STORAGE_BUCKET=your_storage_bucket
APP_CHECK_WEB_PROVIDER=recaptcha_enterprise
APP_CHECK_WEB_RECAPTCHA_ENTERPRISE_SITE_KEY=your_web_recaptcha_enterprise_site_key
APP_CHECK_WEB_RECAPTCHA_SITE_KEY=your_legacy_web_recaptcha_v3_site_key

# AdMob Configuration
ADMOB_APP_ID=ca-app-pub-7587025688858323~3404981432
ADMOB_REWARDED_AD_UNIT_ID=ca-app-pub-7587025688858323/4885584060

# Web Ads Configuration
# ADSENSE_PUBLISHER_ID is the public ca-pub-* client value used by the web shell.
# ADSENSE_CUSTOMER_ID is for account reference only and should not be shipped to
# the browser unless Google explicitly requires it for a product integration.
# GAM_REWARDED_AD_UNIT_PATH is required for true web rewarded ads.
ADSENSE_PUBLISHER_ID=ca-pub-your_publisher_id
ADSENSE_CUSTOMER_ID=your_adsense_customer_id
GAM_REWARDED_AD_UNIT_PATH=/123456789/nurse_singles/rewarded

# Zego Cloud Configuration
# Client only needs the app ID for optional local diagnostics.
# Set ZEGO_SERVER_SECRET as a Firebase Functions secret, never in Flutter.
ZEGO_APP_ID=your_zego_app_id

# RevenueCat Configuration
# Android uses the Google Play public SDK key. Web Billing uses its own
# RevenueCat Web Billing public SDK key from the RevenueCat dashboard.
# Set REVENUECAT_API_KEY as a Firebase Functions secret for backend sync.
REVENUECAT_PUBLIC_API_KEY=your_revenuecat_public_sdk_key
REVENUECAT_WEB_PUBLIC_API_KEY=your_revenuecat_web_billing_public_sdk_key
REVENUECAT_ENTITLEMENT_ID=nurse_singles_pro
REVENUECAT_MONTHLY_PRODUCT_ID=monthly

# Environment
ENVIRONMENT=development
