# Firebase Configuration
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_APP_ID=your_firebase_app_id
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_STORAGE_BUCKET=your_storage_bucket

# AdMob Configuration
ADMOB_APP_ID=ca-app-pub-7587025688858323~3404981432
ADMOB_REWARDED_AD_UNIT_ID=ca-app-pub-7587025688858323/4885584060

# Zego Cloud Configuration
# Client only needs the app ID for optional local diagnostics.
# Set ZEGO_SERVER_SECRET as a Firebase Functions secret, never in Flutter.
ZEGO_APP_ID=your_zego_app_id

# RevenueCat Configuration
# The Flutter app uses only the public SDK key from AppConstants.
# Set REVENUECAT_API_KEY as a Firebase Functions secret for backend sync.
REVENUECAT_PUBLIC_API_KEY=your_revenuecat_public_sdk_key
REVENUECAT_ENTITLEMENT_ID=nurse_singles_pro
REVENUECAT_MONTHLY_PRODUCT_ID=monthly

# Environment
ENVIRONMENT=development
